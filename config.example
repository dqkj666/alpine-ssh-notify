#!/bin/bash

# Alpine SSH Login Telegram Notification - Configuration File
# 配置文件说明:
# 1. TELEGRAM_BOT_TOKEN: 从 @BotFather 获取
# 2. TELEGRAM_CHAT_ID: 从 getUpdates API 获取
# 3. 其他参数可根据需要调整

# ============================================================================
# Telegram 配置 (必需)
# ============================================================================

# Telegram Bot Token
# 获取方法: 在Telegram找到@BotFather，发送/newbot命令
# 格式示例: 123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11
TELEGRAM_BOT_TOKEN="your_bot_token_here"

# Telegram Chat ID
# 获取方法: 给bot发送消息，访问 https://api.telegram.org/bot<TOKEN>/getUpdates
# 格式示例: 987654321 (正数或负数)
TELEGRAM_CHAT_ID="your_chat_id_here"

# ============================================================================
# 公网IP获取配置
# ============================================================================

# 公网IP获取方式
# 可选值: ifconfig, ipify, myip, custom
# - ifconfig: http://ifconfig.me (推荐，国际通用)
# - ipify:    https://api.ipify.org (国际通用)
# - myip:     http://myip.ipip.net (中国IP数据库)
# - custom:   使用 CUSTOM_IP_CMD 中的自定义命令
PUBLIC_IP_METHOD="ifconfig"

# 自定义IP获取命令 (仅当 PUBLIC_IP_METHOD=custom 时使用)
# 示例: CUSTOM_IP_CMD="curl -s https://api.example.com/ip"
# CUSTOM_IP_CMD=""

# ============================================================================
# 日志配置
# ============================================================================

# 日志文件位置
LOG_FILE="/var/log/ssh-notify.log"

# 启用日志记录
# yes: 启用日志，no: 禁用日志
ENABLE_LOG="yes"

# 日志级别
# DEBUG: 详细的调试信息
# INFO:  普通信息 (推荐)
# WARN:  仅警告和错误
# ERROR: 仅错误信息
LOG_LEVEL="INFO"

# ============================================================================
# 网络配置
# ============================================================================

# 请求超时时间 (秒)
# 范围: 1-60
# 推荐: 10
# 网络不稳定时可以增大这个值
TIMEOUT="10"

# 失败重试次数
# 范围: 1-10
# 推荐: 3
# 如果Telegram API请求失败��将自动重试
RETRY_COUNT="3"

# 重试延迟时间 (秒)
# 两次重试之间的等待时间
RETRY_DELAY="2"

# ============================================================================
# 用户过滤配置
# ============================================================================

# 跳过通知的用户 (空格分隔)
# 这些用户登录时不会发送通知
# 示例: SKIP_USERS="root nobody"
# SKIP_USERS=""

# 仅通知指定用户 (空格分隔，留空表示通知所有用户)
# 示例: NOTIFY_USERS="admin ubuntu"
# NOTIFY_USERS=""

# ============================================================================
# 通知内容配置
# ============================================================================

# 发送通知时包含的信息
# yes: 包含此信息
# no:  不包含此信息
INCLUDE_SERVER_IP="yes"
INCLUDE_LOGIN_IP="yes"
INCLUDE_USERNAME="yes"
INCLUDE_TIMESTAMP="yes"

# ============================================================================
# 消息自定义
# ============================================================================

# 通知消息标题
NOTIFICATION_TITLE="🔐 SSH 登录通知"

# 通知消息前缀
NOTIFICATION_PREFIX="您的服务器有新的SSH登录"

# ============================================================================
# 高级配置
# ============================================================================

# 最大消息长度 (字符)
# Telegram有4096字符限制，此值应该小于该值
MAX_MESSAGE_LENGTH="4000"

# 启用详细错误报告
# yes: 详细，no: 简略
VERBOSE_ERROR="yes"

# ============================================================================
# 备注
# ============================================================================

# 编辑此文件后需要重启SSH服务使配置生效:
# rc-service sshd restart  (OpenRC)
# systemctl restart sshd   (systemd)

# 测试配置:
# /opt/alpine-ssh-notify/ssh-notify.sh --test

# 查看日志:
# tail -f /var/log/ssh-notify.log

# 卸载:
# sudo /opt/alpine-ssh-notify/uninstall.sh
